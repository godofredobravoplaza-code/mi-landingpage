            const msgText = "¡Hola! Soy Phenix-Core, el gemelo digital de Phenix. Para optimizar nuestra interacción, me gustaría saber tu nombre. ¿Cómo te llamas?";
            let index = 0;
            
            chatMessages.innerHTML = `
                <div class="flex gap-3 max-w-[85%] animate-slide-in-left mt-2">
                    <img src="assets/phenix_ai_logo.jpg" class="w-8 h-8 rounded-full border border-white/10 flex-shrink-0" alt="IA">
                    <div class="bg-[#AF8282]/10 border border-[#AF8282]/20 rounded-2xl rounded-tl-sm p-4 text-sm text-[#e5e7eb] font-mono shadow-[0_0_15px_rgba(175,130,130,0.05)]" id="typing-bubble">
                        <span id="typing-cursor" class="inline-block w-2 h-4 bg-[#AF8282] animate-pulse align-middle"></span>
                    </div>
                </div>
            `;
            
            const typingBubble = document.getElementById('typing-bubble');
            const typingCursor = document.getElementById('typing-cursor');
            
            function typeLetter() {
                if (index < msgText.length) {
                    typingCursor.remove();
                    typingBubble.innerHTML += msgText.charAt(index);
                    typingBubble.appendChild(typingCursor);
                    index++;
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                    setTimeout(typeLetter, 30); // 30ms por letra
                } else {
                    typingCursor.classList.remove('bg-[#AF8282]');
                    typingCursor.classList.add('bg-transparent'); // Hide cursor when done
                }
            }
            
            setTimeout(typeLetter, 800); // Empezar escritura medio segundo después de despertar
            
            // Cambiar botón a apagar
            const bootBtn = document.getElementById('boot-btn');
            const bootBtnText = document.getElementById('boot-btn-text');
            const bootBtnIcon = document.getElementById('boot-btn-icon');
            if (bootBtn) {
                bootBtn.onclick = iniciarShutdownSequence;
                bootBtn.classList.remove('bg-[#AF8282]', 'hover:bg-white', 'text-black');
                bootBtn.classList.add('bg-black', 'text-[#AF8282]', 'border', 'border-[#AF8282]/50', 'hover:bg-[#AF8282]/10');
                bootBtnText.innerText = "[ APAGAR_NUCLEO ]";
                bootBtnIcon.classList.remove('fa-power-off');
                bootBtnIcon.classList.add('fa-ban');
            }
        }

        function sleepPhenixCore() {
            const chatContainer = document.getElementById('chat-container');
            const chatScanline = document.getElementById('chat-scanline');
            const onlineDot = document.getElementById('online-dot');
            const onlineText = document.getElementById('online-text');
            const headerBtn3 = document.getElementById('header-btn-3');
            const chatMessages = document.getElementById('chat-messages');
            const chatInput = document.getElementById('chat-input');
            const chatSubmitBtn = document.getElementById('chat-submit-btn');
            const phenixStatus = document.getElementById('phenix-status');
            const chatInputArea = document.getElementById('chat-input-area');
            const chatHeader = document.getElementById('chat-header');
            const standbyIndicator = document.getElementById('standby-indicator');
            
            // Mostrar indicador Standby
            if (standbyIndicator) {
                standbyIndicator.classList.remove('opacity-0', 'max-h-0', 'py-0', 'scale-95', 'pointer-events-none');
                standbyIndicator.classList.add('opacity-100', 'max-h-[200px]', 'py-6', 'scale-100');
            }
            
            // Desaparición Mágica (Opción 3)
            chatContainer.classList.add('max-h-0', 'opacity-0', 'scale-95', 'translate-y-4', 'pointer-events-none');
            chatContainer.classList.remove('max-h-[1000px]', 'opacity-100', 'scale-100', 'translate-y-0', 'pointer-events-auto');
            
            // Mensaje offline
            chatMessages.innerHTML = `
                <div class="flex items-center justify-center h-full w-full" id="offline-msg">
                    <span class="text-zinc-600 font-mono text-sm tracking-widest">[ SISTEMA EN REPOSO ]</span>
                </div>
            `;
            
            // Apagar luces
            chatScanline.classList.add('opacity-0');
            chatScanline.classList.remove('opacity-70');
            
            onlineDot.classList.add('bg-zinc-600', 'border-zinc-500');
            onlineDot.classList.remove('bg-green-500', 'border-black', 'animate-pulse');
            
            onlineText.innerHTML = '<span class="w-1.5 h-1.5 bg-zinc-600 rounded-full inline-block"></span> Offline';
            onlineText.classList.add('text-zinc-500');
            onlineText.classList.remove('text-green-400');
            
            if (phenixStatus) {
                phenixStatus.innerText = "Modo Reposo. Esperando directivas.";
                phenixStatus.className = "text-zinc-500";
            }
            
            headerBtn3.classList.add('bg-zinc-700');
            headerBtn3.classList.remove('bg-[#AF8282]/60');
            
            // Deshabilitar input
            chatInput.disabled = true;
            chatInput.value = "";
            chatInput.placeholder = "Sistema desconectado...";
            chatSubmitBtn.disabled = true;
            chatSubmitBtn.classList.add('bg-zinc-700', 'text-zinc-400');
            chatSubmitBtn.classList.remove('bg-gradient-to-r', 'from-[#7a4c4c]', 'to-[#AF8282]', 'text-white', 'hover:scale-105', 'hover:shadow-[0_0_15px_rgba(175,130,130,0.6)]');
            
            // Cambiar botón a iniciar
            const bootBtn = document.getElementById('boot-btn');
            const bootBtnText = document.getElementById('boot-btn-text');
            const bootBtnIcon = document.getElementById('boot-btn-icon');
            if (bootBtn) {
                bootBtn.onclick = iniciarBootSequence;
                bootBtn.classList.add('bg-[#AF8282]', 'hover:bg-white', 'text-black');
                bootBtn.classList.remove('bg-black', 'text-[#AF8282]', 'border', 'border-[#AF8282]/50', 'hover:bg-[#AF8282]/10');
                bootBtnText.innerText = "[ INICIALIZAR_NUCLEO ]";
                bootBtnIcon.classList.add('fa-power-off');
                bootBtnIcon.classList.remove('fa-ban');
            }
        }

        let userName = "";
        let chatStep = 0;

        function iniciarBootSequence() {
            const modal = document.getElementById('modal-boot');
            const terminal = document.getElementById('boot-terminal-content');
            terminal.innerHTML = '';
            modal.classList.remove('opacity-0', 'pointer-events-none');
            
            let delay = 0;
            bootMessages.forEach((msg, index) => {
                setTimeout(() => {
                    terminal.innerHTML += `<div><span class="text-white">></span> ${msg}</div>`;
                    terminal.scrollTop = terminal.scrollHeight;
                    
                    // Si es el último mensaje, esperamos, cerramos modal y scrolleamos al chat
                    if (index === bootMessages.length - 1) {
                        setTimeout(() => {
                            modal.classList.add('opacity-0', 'pointer-events-none');
                            
                            // Despertar la IA visualmente primero
                            wakeUpPhenixCore();
                            
                            // Scrollear DESPUÉS de que la animación de expansión termine (1000ms)
                            setTimeout(() => {
                                document.getElementById('phenix-core').scrollIntoView({ behavior: 'smooth', block: 'center' });
                            }, 1000); 
                            
                            // Forzar que el input reciba el foco
                            setTimeout(() => {
                                document.getElementById('chat-input').focus();
                            }, 1500); // Dar tiempo al scroll y al despertar
                        }, 2500);
                    }
                }, delay);
                // Tiempos incrementales para simular carga real
                delay += Math.floor(Math.random() * 600) + 400;
            });
        }

        function iniciarShutdownSequence() {
            const modal = document.getElementById('modal-boot');
            const terminal = document.getElementById('boot-terminal-content');
            terminal.innerHTML = '';
            modal.classList.remove('opacity-0', 'pointer-events-none');
            
            let delay = 0;
            shutdownMessages.forEach((msg, index) => {
                setTimeout(() => {
                    terminal.innerHTML += `<div><span class="text-red-500">></span> <span class="${msg.includes('[!]') || msg.includes('ADVERTENCIA') ? 'text-red-400' : 'text-zinc-300'}">${msg}</span></div>`;
                    terminal.scrollTop = terminal.scrollHeight;
                    
                    if (index === shutdownMessages.length - 1) {
                        setTimeout(() => {
                            modal.classList.add('opacity-0', 'pointer-events-none');
                            
                            // Apagar la IA visualmente
                            sleepPhenixCore();
                            
                            // Volver a centrar la pantalla en la tarjeta colapsada
                            setTimeout(() => {
                                document.getElementById('phenix-core').scrollIntoView({ behavior: 'smooth', block: 'center' });
                            }, 1000);
                            
                        }, 2500);
                    }
                }, delay);
                delay += Math.floor(Math.random() * 400) + 300;
            });
        }

        function handlePhenixToggle(action) {
            const btnOff = document.getElementById('industrial-off');
            const btnOn = document.getElementById('industrial-on');
            
            // Verificamos si actualmente está online revisando si el botón ON tiene luz
            const isOnline = btnOn.classList.contains('text-white');
            
            if (action === 'on' && !isOnline) {
                // Activar ON
                btnOn.classList.replace('bg-zinc-900', 'bg-[#AF8282]/40');
                btnOn.classList.replace('border-zinc-700', 'border-[#AF8282]');
                btnOn.classList.replace('text-zinc-600', 'text-white');
                btnOn.classList.remove('hover:bg-zinc-800');
                btnOn.classList.add('shadow-[0_0_20px_rgba(175,130,130,0.5),inset_0_2px_10px_rgba(255,255,255,0.1)]');
                
                // Desactivar OFF
                btnOff.classList.replace('bg-red-900/40', 'bg-zinc-900');
                btnOff.classList.replace('border-red-500/50', 'border-zinc-700');
                btnOff.classList.replace('text-white', 'text-zinc-600');
                btnOff.classList.add('hover:bg-zinc-800');
                btnOff.classList.remove('shadow-[0_0_15px_rgba(220,38,38,0.5),inset_0_2px_10px_rgba(255,255,255,0.1)]');
                
                iniciarBootSequence();
            } else if (action === 'off' && isOnline) {
                // Activar OFF
                btnOff.classList.replace('bg-zinc-900', 'bg-red-900/40');
                btnOff.classList.replace('border-zinc-700', 'border-red-500/50');
                btnOff.classList.replace('text-zinc-600', 'text-white');
                btnOff.classList.remove('hover:bg-zinc-800');
                btnOff.classList.add('shadow-[0_0_15px_rgba(220,38,38,0.5),inset_0_2px_10px_rgba(255,255,255,0.1)]');
                
                // Desactivar ON
                btnOn.classList.replace('bg-[#AF8282]/40', 'bg-zinc-900');
                btnOn.classList.replace('border-[#AF8282]', 'border-zinc-700');
                btnOn.classList.replace('text-white', 'text-zinc-600');
                btnOn.classList.add('hover:bg-zinc-800');
                btnOn.classList.remove('shadow-[0_0_20px_rgba(175,130,130,0.5),inset_0_2px_10px_rgba(255,255,255,0.1)]');
                
                iniciarShutdownSequence();
            }
        }

        // Evento chat-form redundante eliminado
    </script>
</body>
