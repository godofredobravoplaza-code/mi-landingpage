    <!-- Scripts -->
    <script>
        // --- Menú Móvil ---
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const icon = btn.querySelector('i');

        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
            if (menu.classList.contains('hidden')) {
                icon.classList.remove('fa-xmark');
                icon.classList.add('fa-bars');
            } else {
                icon.classList.remove('fa-bars');
                icon.classList.add('fa-xmark');
            }
        });

        // --- Tarjetas 3D Auto-Reverso ---
        // Si el usuario saca el mouse de la tarjeta volteada, se regresará a su estado original tras 3 segundos.
        const cards = ['card-1', 'card-2', 'step-1', 'step-2', 'step-3'];
        const flipTimers = {};

        cards.forEach(cardId => {
            const cardElement = document.getElementById(cardId);
            if (!cardElement) return;

            // Cuando el mouse sale de la tarjeta
            cardElement.addEventListener('mouseleave', () => {
                // Solo inicia el temporizador si la tarjeta está volteada
                if (cardElement.classList.contains('[transform:rotateY(180deg)]')) {
                    flipTimers[cardId] = setTimeout(() => {
                        cardElement.classList.remove('[transform:rotateY(180deg)]');
                    }, 3000); // 3000 milisegundos = 3 segundos
                }
            });

            // Si el mouse vuelve a entrar antes de los 3 segundos, cancelamos el giro automático
            cardElement.addEventListener('mouseenter', () => {
                if (flipTimers[cardId]) {
                    clearTimeout(flipTimers[cardId]);
                    delete flipTimers[cardId];
                }
            });
        });

        // --- Animación Botón Enviar y AJAX ---
        const contactForm = document.querySelector('form[action="https://api.web3forms.com/submit"]');
        const successModal = document.getElementById('success-modal');
        const successCard = document.getElementById('success-card');
        const countdownEl = document.getElementById('countdown');

        if (contactForm) {
            contactForm.addEventListener('submit', function(e) {
                e.preventDefault(); // Detener el envío automático que recarga la página
                
                // Obtener el primer nombre del usuario para personalizar el mensaje
                const nombreCompleto = document.getElementById('nombre').value;
                const primerNombre = nombreCompleto.split(' ')[0];
                document.getElementById('success-name').innerText = primerNombre;
                
                const btn = document.getElementById('submit-btn');
                const btnText = document.getElementById('submit-text');
                const btnIcon = document.getElementById('submit-icon');
                
                // Guardar estado original
                const originalText = btnText.innerText;
                const originalIconClass = btnIcon.className;
                const originalBtnClass = btn.className;
                
                // Cambiar estado a "Enviando..."
                btnText.innerText = "Enviando con prioridad!!!";
                btnIcon.className = "fa-solid fa-spinner fa-spin ml-2"; // Icono de carga
                
                // Cambiar botón a color corporativo y efecto de pulso
                btn.className = "w-full inline-flex items-center justify-center px-8 py-3.5 text-sm font-bold text-white bg-[#AF8282] rounded-lg transition-all duration-300 ease-out animate-pulse shadow-[0_0_20px_rgba(175,130,130,0.6)]";
                
                // Esperar 3 segundos antes de enviar realmente
                setTimeout(() => {
                    // Recolectar datos del formulario
                    const formData = new FormData(contactForm);
                    
                    // Enviar vía AJAX (fetch) para no salir de la página
                    fetch(contactForm.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'Accept': 'application/json'
                        }
                    })
                    .then(response => {
                        if(response.ok) {
                            // Restaurar botón y limpiar formulario
                            btnText.innerText = originalText;
                            btnIcon.className = originalIconClass;
                            btn.className = originalBtnClass;
                            contactForm.reset();
                            
                            // Mostrar Modal de Éxito
                            successModal.classList.remove('opacity-0', 'pointer-events-none');
                            successCard.classList.remove('scale-95');
                            successCard.classList.add('scale-100');
                            
                            // Iniciar cuenta regresiva
                            let timeLeft = 6;
                            countdownEl.innerText = timeLeft;
                            
                            const timer = setInterval(() => {
                                timeLeft--;
                                countdownEl.innerText = timeLeft;
                                if(timeLeft <= 0) {
                                    clearInterval(timer);
                                    // Ocultar Modal
                                    successModal.classList.add('opacity-0', 'pointer-events-none');
                                    successCard.classList.remove('scale-100');
                                    successCard.classList.add('scale-95');
                                }
                            }, 1000);
                        } else {
                            throw new Error('Error en la respuesta del servidor');
                        }
                    })
                    .catch(error => {
                        alert("Hubo un error al enviar el mensaje. Por favor intenta contactarnos por WhatsApp.");
                        btnText.innerText = originalText;
                        btnIcon.className = originalIconClass;
                        btn.className = originalBtnClass;
                    });
                }, 3000);
            });
        }
        // Phenix-Core (Beta) Chat Logic
        const chatForm = document.getElementById('chat-form');
        const chatInput = document.getElementById('chat-input');
        const chatMessages = document.getElementById('chat-messages');

        if(chatForm) {
            chatForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const msg = chatInput.value.trim();
                if(!msg) return;

                // Mostrar mensaje del usuario
                appendUserMessage(msg);
                chatInput.value = '';
                
                // Eliminar cursores anteriores si existen (por la bienvenida)
                const oldCursors = document.querySelectorAll('[id^="typing-cursor"]');
                oldCursors.forEach(c => c.remove());

                // Mostrar indicador de "escribiendo..."
                const typingId = 'typing-' + Date.now();
                showTypingIndicator(typingId);

                // Simular delay y responder
                setTimeout(() => {
                    const typingIndicator = document.getElementById(typingId);
                    if(typingIndicator) typingIndicator.remove();
                    
                    let response = "";
                    if (chatStep === 0) {
                        userName = msg;
                        const firstName = userName.split(" ")[0];
                        response = `Encantado de conocerte, ${firstName}. He registrado tu perfil en mi núcleo temporal. ¿En qué te puedo ayudar hoy?<br><br><span class="text-xs text-zinc-500">Si deseas explorar por tu cuenta, puedes apagar el sistema:</span><br><button type="button" onclick="document.getElementById('industrial-off').click()" class="mt-2 inline-flex items-center px-4 py-2 text-[11px] font-bold text-zinc-400 bg-zinc-900/80 rounded-md hover:bg-red-900/30 hover:text-red-400 border border-zinc-800 hover:border-red-900/50 transition-all duration-300"><i class="fa-solid fa-power-off mr-1.5"></i> Apagar Phenix Core</button>`;
                        chatStep = 1;
                    } else {
                        response = getAIResponse(msg.toLowerCase(), userName);
                    }
                    
                    appendAIMessage(response);
                }, 1500 + Math.random() * 1000);
            });
        }

        function appendUserMessage(text) {
            const html = `
                <div class="flex gap-3 max-w-[85%] self-end flex-row-reverse animate-slide-in-right">
                    <div class="w-8 h-8 rounded-full bg-white/10 border border-white/20 flex items-center justify-center flex-shrink-0">
                        <i class="fa-regular fa-user text-xs text-white"></i>
                    </div>
                    <div class="bg-white/10 border border-white/5 rounded-2xl rounded-tr-sm p-3 text-sm text-white">
                        ${escapeHtml(text)}
                    </div>
                </div>
            `;
            chatMessages.insertAdjacentHTML('beforeend', html);
            scrollToBottom();
        }

        function showTypingIndicator(id) {
            const html = `
                <div id="${id}" class="flex gap-3 max-w-[85%] animate-slide-in-left">
                    <img src="assets/phenix_ai_logo.jpg" class="w-8 h-8 rounded-full border border-white/10 flex-shrink-0" alt="IA">
                    <div class="bg-[#AF8282]/10 border border-[#AF8282]/20 rounded-2xl rounded-tl-sm p-4 flex items-center gap-1.5 shadow-[0_0_15px_rgba(175,130,130,0.05)]">
                        <span class="w-1.5 h-1.5 bg-[#AF8282] rounded-full animate-bounce [animation-delay:-0.3s]"></span>
                        <span class="w-1.5 h-1.5 bg-[#AF8282] rounded-full animate-bounce [animation-delay:-0.15s]"></span>
                        <span class="w-1.5 h-1.5 bg-[#AF8282] rounded-full animate-bounce"></span>
                    </div>
                </div>
            `;
            chatMessages.insertAdjacentHTML('beforeend', html);
            scrollToBottom();
        }

        function appendAIMessage(text) {
            const msgId = 'msg-' + Date.now();
            const html = `
                <div class="flex gap-3 max-w-[85%] animate-slide-in-left">
                    <img src="assets/phenix_ai_logo.jpg" class="w-8 h-8 rounded-full border border-white/10 flex-shrink-0" alt="IA">
                    <div class="bg-[#AF8282]/10 border border-[#AF8282]/20 rounded-2xl rounded-tl-sm p-4 text-sm text-[#e5e7eb] font-mono shadow-[0_0_15px_rgba(175,130,130,0.05)]">
                        <span id="${msgId}"></span><span class="inline-block w-1.5 h-3 ml-1 bg-[#AF8282] animate-pulse align-middle"></span>
                    </div>
                </div>
            `;
            chatMessages.insertAdjacentHTML('beforeend', html);
            scrollToBottom();

            const target = document.getElementById(msgId);
            
